DEEPSEEK_API_KEY=

# M1 server + PostgreSQL
DATABASE_URL=postgresql+asyncpg://billmind:billmind@localhost:5432/billmind

# HTTP 集成测试（server/api）访问的 API 地址，默认本机 8000
# API_BASE_URL=http://127.0.0.1:8000

# 可选：终端 SOCKS 代理时必须走代理时设为 1，并 pip install "httpx[socks]"
# DEEPSEEK_USE_SYSTEM_PROXY=0

# Ollama（Docker：docker compose up -d ollama；视觉示例见 examples/01_image_ollama_chain/）
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_VISION_MODEL=qwen2.5vl:7b

# M3 Web CORS（逗号分隔多个 origin，默认 127.0.0.1:5173 与 localhost:5173）
# WEB_ORIGIN=http://127.0.0.1:5173

# M6 高德 MCP（Streamable HTTP，勿提交真实 Key）
# AMAP_MAPS_API_KEY=

# M6 本地开发固定 IP（127.0.0.1 / VPN 公网 IP 高德无法解析时可设；留空则使用登录用户真实 IP）
# GEO_DEFAULT_IP=112.48.54.75

# M7 RAG（Milvus + Ollama embedding）
# MILVUS_URI=http://127.0.0.1:19530
# OLLAMA_URI=http://localhost:11434
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text   # compose 启动 ollama 后由 ollama-pull-embeddings 自动 pull
# RAG_TOP_K=4

# M8 交易语义搜索（记账后自动 upsert 向量，设为 0 关闭）
# TXN_SEARCH_INCREMENTAL=1
